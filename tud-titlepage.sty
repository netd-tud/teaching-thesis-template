%% tud-titlepage.sty
%% TU Dresden Corporate Design title page for KOMA-Script thesis template.
%%
%% Provides:
%%   - Metadata commands: \faculty, \institute, \chair, \thesis, \graduation,
%%     \supervisor, \cosupervisor, \professor, \reviewer, \matriculationnumber,
%%     \dateofbirth, \placeofbirth, \email
%%   - Three title styles via \titlestyle{...}:
%%       plain      — white background with a colored accent band (top-right)
%%       unicolor   — full-page solid color background
%%       shapes     — full-page background with the TUD CD logo-mark shape overlay
%%   - Shape placement control: \titleshapevariant (presets 1–5),
%%     \titleshaperotation (steps of 45°), \titleshapescale, \titleshapeoffset
%%   - Automatic logo/text color selection based on background color
%%   - Manual overrides: \logocolor, \logovariant, \accentcolor,
%%     \titlebgcolor, \titleshapecolor, \titletextcolor
%%
%% Requires: KOMA-Script class (scrbook/scrreprt/scrartcl), tud-colors,
%%           graphicx, tikz, babel. Logo files must be present in figures/:
%%             tud-logo-blau-en.pdf / tud-logo-blau-de.pdf
%%             tud-logo-weiss-en.pdf / tud-logo-weiss-de.pdf

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{tud-titlepage}[2026/04/01 TUD CD Thesis Title Page]

\@ifundefined{setkomafont}{%
  \PackageError{tud-titlepage}%
    {A KOMA-Script class is required}%
    {Load scrreprt, scrartcl, or scrbook before this package.}%
}{}
\RequirePackage{tud-colors}
\RequirePackage{graphicx}
\RequirePackage{tikz}
% \iflanguage is provided by babel (loaded in thesis.tex)

%% ============================================================
%% Title page dimensions (A4)
%% ============================================================
\newlength{\tud@logoheight}   \setlength{\tud@logoheight}{19mm}
\newlength{\tud@shapeunit}
\newlength{\tud@effectiveshapeunit}
\newlength{\tud@bandwidth}    \setlength{\tud@bandwidth}{28mm}
\newlength{\tud@bandheight}   \setlength{\tud@bandheight}{110mm}
\newlength{\tud@marginleft}   \setlength{\tud@marginleft}{15mm}
\newlength{\tud@marginright}  \setlength{\tud@marginright}{10mm}
\newlength{\tud@margintop}    \setlength{\tud@margintop}{15mm}
\newlength{\tud@marginbottom} \setlength{\tud@marginbottom}{24mm}
% Gap between text block and accent band
\newlength{\tud@bandgap}      \setlength{\tud@bandgap}{6mm}
% Text content width (left margin to just before band gap)
% = paperwidth - left - right - band - gap
% = 210mm - 15mm - 10mm - 28mm - 6mm = 151mm
\newlength{\tud@textwidth}
\setlength{\tud@textwidth}{\dimexpr\paperwidth-\tud@marginleft-\tud@marginright-\tud@bandwidth-\tud@bandgap}

%% ============================================================
%% Internal metadata storage (use \def for reliable \ifx tests)
%% ============================================================
\def\tud@faculty{}
\def\tud@department{}
\def\tud@institute{}
\def\tud@chair{}
\def\tud@thesistype{}
\def\tud@graduationshort{}
\def\tud@graduationlong{}
\def\tud@matriculationnumber{}
\def\tud@dateofbirth{}
\def\tud@placeofbirth{}
\def\tud@supervisor{}
\def\tud@professor{}
% \subtitle is provided by KOMA-Script (scrreprt); it stores into \@subtitle
\def\tud@cosupervisor{}
\def\tud@email{}
\def\tud@reviewer{}
\def\tud@accentcolor{Brilliantblau}
\def\tud@logovariant{en}
\def\tud@logocolor{blau}    % auto-set from bgcolor; override with \logocolor
%% Title style (set by \titlestyle)
\def\tud@titlestyle{plain}
\def\tud@titlebg{0}
\def\tud@titleshapes{0}
\def\tud@bgcolor{white}
\def\tud@shapecolor{Brilliantblau}
\def\tud@titlefgcolor{black}
\def\tud@titleaccentcolor{\tud@accentcolor}
\def\tud@shaperotation{0}
\def\tud@shapescale{1}
\def\tud@shapexoffset{0pt}
\def\tud@shapeyoffset{-43.5mm}  % SW-anchor equivalent for A4 (=(297-210)/2)

%% Auto-detect logo color + text color from \tud@bgcolor.
%% Any dark TUD color → weiss logo + white text; otherwise blau logo + black text.
\newcommand{\tud@autologocolor}{%
  \def\tud@logocolor{blau}%
  \def\tud@titlefgcolor{black}%
  \def\tud@titleaccentcolor{\tud@accentcolor}%
  \@for\tud@iter:={Brilliantblau,Dunkelblau,Blau1,Violett1,Magenta1,%
                   Rot1,Orange1,Oliv1,Gruen1,Tuerkis1,Grau100,Grau80,Grau60}\do{%
    \ifx\tud@bgcolor\tud@iter
      \def\tud@logocolor{weiss}%
      \def\tud@titlefgcolor{white}%
      \def\tud@titleaccentcolor{white}%
    \fi
  }%
}

%% ============================================================
%% User-facing metadata commands
%% ============================================================
\newcommand{\faculty}[1]{\def\tud@faculty{#1}}
\newcommand{\department}[1]{\def\tud@department{#1}}
\newcommand{\institute}[1]{\def\tud@institute{#1}}
\newcommand{\chair}[1]{\def\tud@chair{#1}}
\newcommand{\thesis}[1]{\def\tud@thesistype{#1}}
\newcommand{\graduation}[2][]{\def\tud@graduationshort{#1}\def\tud@graduationlong{#2}}
\newcommand{\matriculationnumber}[1]{\def\tud@matriculationnumber{#1}}
\newcommand{\dateofbirth}[1]{\def\tud@dateofbirth{#1}}
\newcommand{\placeofbirth}[1]{\def\tud@placeofbirth{#1}}
\newcommand{\supervisor}[1]{\def\tud@supervisor{#1}}
\newcommand{\professor}[1]{\def\tud@professor{#1}}
% \subtitle is provided by KOMA-Script; no redefinition needed here
\newcommand{\cosupervisor}[1]{\def\tud@cosupervisor{#1}}
\newcommand{\email}[1]{\def\tud@email{#1}}
\newcommand{\reviewer}[1]{\def\tud@reviewer{#1}}
\newcommand{\accentcolor}[1]{\def\tud@accentcolor{#1}}
\newcommand{\logovariant}[1]{\def\tud@logovariant{#1}}
\newcommand{\logocolor}[1]{\def\tud@logocolor{#1}}
% \titlestyle — three overloaded signatures (dispatched on mandatory #5):
%
%   \titlestyle[textcolor][bgcolor]{unicolor}
%     Solid color background. bgcolor defaults to Brilliantblau.
%     textcolor is inferred from bgcolor via \tud@autologocolor unless overridden.
%
%   \titlestyle[variant][accent|tonal]{shapes}
%     Shapes style. variant = 1–5 (default 5). scheme = accent or tonal (default tonal).
%
%   \titlestyle[variant][textcolor][shapecolor][bgcolor]{shapes}
%     Shapes style, fully custom. All optionals default to the tonal preset values.
%
%   \titlestyle{plain}  — plain white background, accent band
\NewDocumentCommand{\titlestyle}{o o o o m}{%
  %--- reset all shape/bg/color state ---%
  \def\tud@titlestyle{#5}%
  \def\tud@titlebg{0}\def\tud@titleshapes{0}%
  \def\tud@bgcolor{white}\def\tud@shapecolor{Brilliantblau}%
  \def\tud@shaperotation{0}%
  \def\tud@shapescale{1}%
  \def\tud@shapexoffset{0pt}%
  \def\tud@shapeyoffset{-43.5mm}%
  %--- dispatch on mandatory style name ---%
  \def\tud@ts@uc{unicolor}%
  \def\tud@ts@sh{shapes}%
  \def\tud@ts@pl{plain}%
  %
  \ifx\tud@titlestyle\tud@ts@uc
    %--- unicolor: #1=textcolor (opt), #2=bgcolor (opt) ---%
    \def\tud@titlebg{1}%
    \IfNoValueTF{#2}%
      {\def\tud@bgcolor{Brilliantblau}}%
      {\def\tud@bgcolor{#2}}%
    \tud@autologocolor
    \IfNoValueF{#1}{\def\tud@titlefgcolor{#1}}%
  \fi
  %
  \ifx\tud@titlestyle\tud@ts@sh
    \def\tud@titlebg{1}\def\tud@titleshapes{1}%
    \IfNoValueTF{#3}{%
      %--- 2-optional path: #1=variant (opt), #2=accent|tonal (opt) ---%
      \def\tud@ts@accent{accent}%
      \IfNoValueTF{#2}{\def\tud@ts@scheme{tonal}}{\def\tud@ts@scheme{#2}}%
      \ifx\tud@ts@scheme\tud@ts@accent
        \def\tud@bgcolor{white}\def\tud@shapecolor{Blau2}%
      \else
        \def\tud@bgcolor{Dunkelblau}\def\tud@shapecolor{Brilliantblau}%
      \fi
      \tud@autologocolor
      \IfNoValueTF{#1}{\titleshapevariant{5}}{\titleshapevariant{#1}}%
    }{%
      %--- 4-optional path: #1=variant, #2=textcolor, #3=shapecolor, #4=bgcolor ---%
      \def\tud@bgcolor{Dunkelblau}\def\tud@shapecolor{Brilliantblau}%
      \tud@autologocolor
      \IfNoValueF{#4}{\def\tud@bgcolor{#4}\tud@autologocolor}%
      \IfNoValueF{#3}{\def\tud@shapecolor{#3}}%
      \IfNoValueF{#2}{\def\tud@titlefgcolor{#2}}%
      \IfNoValueTF{#1}{\titleshapevariant{5}}{\titleshapevariant{#1}}%
    }%
  \fi
  % plain: no bg, no shapes — reset state is already correct; infer logo/text colors
  \ifx\tud@titlestyle\tud@ts@pl
    \tud@autologocolor
  \fi
}
\newcommand{\titlebgcolor}[1]{\def\tud@bgcolor{#1}\tud@autologocolor}
\newcommand{\titleshapecolor}[1]{\def\tud@shapecolor{#1}}
\newcommand{\titletextcolor}[1]{\def\tud@titlefgcolor{#1}}
% #1 = rotation step 0–7; stored angle = #1 × 45°.
% For an arbitrary angle bypass: \def\tud@shaperotation{DEG}
\newcommand{\titleshaperotation}[1]{%
  \edef\tud@shaperotation{\the\numexpr #1*45\relax}%
}
\newcommand{\titleshapescale}[1]{\def\tud@shapescale{#1}}
\newcommand{\titleshapeoffset}[2]{\def\tud@shapexoffset{#1}\def\tud@shapeyoffset{#2}}
%% Predefined shape placement presets (used by \titlestyle{shapes} automatically).
%% Can also be called manually after \titlestyle to override the variant.
%% Each preset sets scale, rotation step (multiples of 45°), and page-center offset.
\newcommand{\titleshapevariant}[1]{%
  \ifcase#1\relax
  \or % 1 — 90°, large, shifted to upper-left
    \titleshapescale{4}\titleshaperotation{2}\titleshapeoffset{-15cm}{40cm}%
  \or % 2 — 90°, medium, near center
    \titleshapescale{2.75}\titleshaperotation{2}\titleshapeoffset{-10cm}{2cm}%
  \or % 3 — 0°, 2×, centered
    \titleshapescale{2}\titleshaperotation{0}\titleshapeoffset{0cm}{0cm}%
  \or % 4 — 0°, large, shifted to lower-right
    \titleshapescale{4}\titleshaperotation{0}\titleshapeoffset{25cm}{-15cm}%
  \or % 5 — 0°, medium-large, shifted to lower-right
    \titleshapescale{2.75}\titleshaperotation{0}\titleshapeoffset{12.5cm}{-12.5cm}%
  \fi
}

%% ============================================================
%% Helper: thesis type label (bilingual)
%% ============================================================
\newcommand{\tud@thesislabel}{%
  \def\@tud@tmpmaster{master}%
  \ifx\tud@thesistype\@tud@tmpmaster
    \iflanguage{ngerman}{Masterarbeit}{Master's Thesis}%
  \else
    \iflanguage{ngerman}{Bachelorarbeit}{Bachelor's Thesis}%
  \fi
}

%% Bilingual labels
\newcommand{\tud@lbl@supervisor}{\iflanguage{ngerman}{Betreuer}{Supervisor}}
\newcommand{\tud@lbl@cosupervisor}{\iflanguage{ngerman}{Zweiter Betreuer}{Co-Supervisor}}
\newcommand{\tud@lbl@reviewer}{\iflanguage{ngerman}{Gutachter}{Reviewer}}
\newcommand{\tud@lbl@secondreviewer}{\iflanguage{ngerman}{Zweiter Gutachter}{Second Reviewer}}
\newcommand{\tud@lbl@submitted}{\iflanguage{ngerman}{Eingereicht am}{Date of Submission}}
\newcommand{\tud@lbl@matrnr}{\iflanguage{ngerman}{Matrikelnummer}{Matriculation Number}}
\newcommand{\tud@lbl@born}{\iflanguage{ngerman}{geboren am}{born}}

%% ============================================================
%% \maketitle — TUD CD title page
%%
%% Uses tikz overlays for:
%%   - full-page background fill (unicolor / shapes styles)
%%   - TUD CD logo-mark shape polygons (shapes style)
%%   - accent color band, top-right (plain style only)
%%   - TUD logo, top-left
%%   - title / thesis-type content block, upper-left
%%   - author / supervisor / date metadata block, lower-left
%% All coordinates are relative to current page corners so the
%% layout is independent of the main document's margin settings.
%% ============================================================
\renewcommand{\maketitle}{%
  \begin{titlepage}%
    \thispagestyle{empty}%
    \begin{tikzpicture}[remember picture, overlay]
      \def\tud@flag@one{1}%
      %--- Full-page background fill (non-plain styles) ---%
      \ifx\tud@titlebg\tud@flag@one
        \fill[\tud@bgcolor]
          (current page.south west) rectangle (current page.north east);
      \fi
      %--- Shape polygons (shapes-tonal / shapes-accent) ---%
      \ifx\tud@titleshapes\tud@flag@one
        \setlength{\tud@shapeunit}{\dimexpr\paperwidth/600\relax}%
        \setlength{\tud@effectiveshapeunit}{\tud@shapescale\tud@shapeunit}%
        \begin{scope}[
          shift={(current page.center)},
          xshift=\tud@shapexoffset,
          yshift=\tud@shapeyoffset,
          rotate=\tud@shaperotation,
          x=\tud@effectiveshapeunit,
          y=\tud@effectiveshapeunit,
        ]
          \fill[\tud@shapecolor]  % Fragment 1 (upper-right, centered at origin)
            (300,-56.5)--(93,-93)--(93,93)--(-114,300)--(124.3,300)--(300,124.3)--cycle;
          \fill[\tud@shapecolor]  % Fragment 2 (lower-left, centered at origin)
            (-300,56.5)--(-93,93)--(-93,-93)--(114,-300)--(-124.3,-300)--(-300,-124.3)--cycle;
        \end{scope}
      \fi
      %--- Accent band: top-right, plain style only ---%
      \def\tud@ts@plain{plain}\ifx\tud@titlestyle\tud@ts@plain
      \fill[\tud@accentcolor]
        (current page.north east)
        rectangle
        ++(-\tud@bandwidth, -\tud@bandheight);
      \fi
      %--- TUD Logo: top-left, inset by margins ---%
      \node[anchor=north west, inner sep=0pt, outer sep=0pt]
        at ([xshift=\tud@marginleft, yshift=-\tud@margintop]current page.north west)
        {\includegraphics[height=\tud@logoheight]{figures/tud-logo-\tud@logocolor-\tud@logovariant}};
      %--- Title / thesis-type content block ---%
      %    Starts below the logo protection zone (2 × logo height = 38mm from top)
      %    plus top margin (15mm) → 53mm from top, plus a small visual gap
      \node[anchor=north west, inner sep=0pt, outer sep=0pt,
            text width=\tud@textwidth, align=left]
        at ([xshift=\tud@marginleft, yshift=-57mm]current page.north west)
        {%
          \setlength{\parskip}{0pt}%
          \setlength{\parindent}{0pt}%
          \raggedright\sffamily\color{\tud@titlefgcolor}%
          % Organizational hierarchy (stacked: faculty / institute / chair)
          \ifx\tud@faculty\@empty\else
            {\footnotesize%
              \tud@faculty%
              \ifx\tud@institute\@empty\else\\\tud@institute\fi
              \ifx\tud@chair\@empty\else\\\tud@chair\fi
            \par\vspace{6mm}}%
          \fi
          % Title
          {\fontsize{26pt}{30pt}\selectfont\bfseries\color{\tud@titleaccentcolor}\@title\par}%
          % Subtitle (stored by KOMA's \subtitle command into \@subtitle)
          \ifx\@subtitle\@empty\else
            \vspace{3mm}%
            {\fontsize{17pt}{21pt}\selectfont\@subtitle\par}%
          \fi
          \vspace{5mm}%
          % Thesis type + degree abbreviation
          {\large%
            \tud@thesislabel%
            \ifx\tud@graduationshort\@empty\else\space(\tud@graduationshort)\fi
          \par}%
        };
      %--- Metadata block: anchored to bottom-left ---%
      \node[anchor=south west, inner sep=0pt, outer sep=0pt,
            text width=\tud@textwidth, align=left]
        at ([xshift=\tud@marginleft, yshift=\tud@marginbottom]current page.south west)
        {%
          \setlength{\parskip}{1.5pt}%
          \setlength{\parindent}{0pt}%
          \raggedright\sffamily\color{\tud@titlefgcolor}%
          % Author name
          {\large\bfseries\@author\par}%
          \ifx\tud@email\@empty\else
            {\small\tud@email\par}%
          \fi
          \ifx\tud@matriculationnumber\@empty\else
            {\small\tud@lbl@matrnr: \tud@matriculationnumber\par}%
          \fi
          \ifx\tud@dateofbirth\@empty\else
            {\small\tud@lbl@born\ \tud@dateofbirth%
              \ifx\tud@placeofbirth\@empty\else,\space\tud@placeofbirth\fi
            \par}%
          \fi
          \vspace{4mm}%
          % Supervisors and reviewers — two-column tabular so names left-align
          {\small
          \begin{tabular}[t]{@{}l@{\hspace{0.4em}}l@{}}
            \ifx\tud@professor\@empty\else
              \tud@lbl@reviewer: & \tud@professor \\
            \fi
            \ifx\tud@reviewer\@empty\else
              \tud@lbl@secondreviewer: & \tud@reviewer \\
            \fi
            \ifx\tud@supervisor\@empty\else
              \tud@lbl@supervisor: & \tud@supervisor \\
            \fi
            \ifx\tud@cosupervisor\@empty\else
              \tud@lbl@cosupervisor: & \tud@cosupervisor \\
            \fi
          \end{tabular}%
          \par}%
          \vspace{4mm}%
          % Submission date
          {\small\tud@lbl@submitted: \@date}%
        };
    \end{tikzpicture}%
    \null\vfill  % ensure the titlepage spans a full page
  \end{titlepage}%
}
